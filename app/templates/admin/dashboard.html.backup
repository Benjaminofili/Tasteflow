    <!-- Toast Notification Container -->
    <div id="toast" class="fixed bottom-6 left-1/2 -translate-x-1/2 opacity-0 pointer-events-none z-50 flex items-center gap-3 px-5 py-3.5 rounded-full shadow-2xl text-white text-sm font-medium transition-all duration-300 transform translate-y-4" style="background:#1e293b;">
        <svg id="toast-icon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"></svg>
        <span id="toast-msg"></span>
    </div>

    <script>
        // Dark mode toggle
        const darkModeToggle = document.getElementById('darkModeToggle');
        const html = document.documentElement;
        
        // Check for saved theme preference or default to light
        const currentTheme = localStorage.getItem('theme') || 'light';
        if (currentTheme === 'dark') {
            html.classList.add('dark');
        }
        
        darkModeToggle.addEventListener('click', () => {
            html.classList.toggle('dark');
            const theme = html.classList.contains('dark') ? 'dark' : 'light';
            localStorage.setItem('theme', theme);
        });

        // Toast System
        function showToast(message, type = 'success') {
            const toast = document.getElementById('toast');
            const msgEl = document.getElementById('toast-msg');
            const iconEl = document.getElementById('toast-icon');

            msgEl.textContent = message;

            if (type === 'success') {
                iconEl.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />';
                iconEl.classList.remove('text-red-400');
                iconEl.classList.add('text-emerald-400');
            } else {
                iconEl.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />';
                iconEl.classList.remove('text-emerald-400');
                iconEl.classList.add('text-red-400');
            }

            toast.classList.remove('opacity-0', 'translate-y-4');
            toast.classList.add('opacity-100', 'translate-y-0');

            setTimeout(() => {
                toast.classList.remove('opacity-100', 'translate-y-0');
                toast.classList.add('opacity-0', 'translate-y-4');
            }, 3000);
        }
    </script>

    <script>
        document.addEventListener('DOMContentLoaded', fetchDashboardData);

        async function fetchDashboardData() {
            try {
                // Fetch from the API route we just fixed
                const response = await fetch('/admin/api/dashboard');
                const data = await response.json();

                if (!response.ok) {
                    if (response.status === 403 || response.status === 401) {
                        window.location.href = '/admin/login';
                    }
                    throw new Error(data.message || 'Failed to load dashboard data');
                }

                // 1. Populate Stats Cards
                const stats = data.stats;
                if (document.getElementById('stat-revenue')) {
                    document.getElementById('stat-revenue').textContent = `₦${stats.total_revenue.toLocaleString()}`;
                }
                if (document.getElementById('stat-orders')) {
                    document.getElementById('stat-orders').textContent = stats.orders_count.toLocaleString();
                }
                if (document.getElementById('stat-customers')) {
                    document.getElementById('stat-customers').textContent = stats.users_count.toLocaleString();
                }
                if (document.getElementById('stat-restaurants')) {
                    document.getElementById('stat-restaurants').textContent = stats.restaurants_count.toLocaleString();
                }

                // 2. Populate Recent Orders Table
                const ordersTbody = document.getElementById('recent-orders-tbody');
                if (ordersTbody && data.recent_activity && data.recent_activity.orders) {
                    ordersTbody.innerHTML = '';
                    data.recent_activity.orders.forEach(order => {
                        const date = new Date(order.order_date).toLocaleDateString();
                        // Map status to Tailwind colors
                        const statusColors = {
                            'pending': 'bg-orange-100 text-orange-800',
                            'preparing': 'bg-blue-100 text-blue-800',
                            'out for delivery': 'bg-purple-100 text-purple-800',
                            'delivered': 'bg-green-100 text-green-800',
                            'cancelled': 'bg-red-100 text-red-800'
                        };
                        const colorClass = statusColors[order.status.toLowerCase()] || 'bg-gray-100 text-gray-800';

                        const row = `
                            <tr>
                                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900 dark:text-white">#TF-${order.id}</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400">${date}</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-white">${order.restaurant_name}</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-white">${order.customer_name}</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-white">₦${order.total_amount.toLocaleString()}</td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <span class="px-2 py-1 inline-flex text-xs leading-5 font-semibold rounded-full ${colorClass}">
                                        ${order.status_label}
                                    </span>
                                </td>
                            </tr>
                        `;
                        ordersTbody.insertAdjacentHTML('beforeend', row);
                    });
                }

                // 3. Populate Recent Users Table
                const usersTbody = document.getElementById('recent-users-tbody');
                if (usersTbody && data.recent_activity && data.recent_activity.users) {
                    usersTbody.innerHTML = '';
                    data.recent_activity.users.forEach(user => {
                        const date = new Date(user.created_at).toLocaleDateString();
                        const roleColors = {
                            'admin': 'bg-red-100 text-red-800',
                            'owner': 'bg-blue-100 text-blue-800',
                            'customer': 'bg-green-100 text-green-800'
                        };
                        const roleColor = roleColors[user.role] || 'bg-gray-100 text-gray-800';

                        const row = `
                            <tr>
                                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900 dark:text-white">${user.name}</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400">${user.email}</td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <span class="px-2 py-1 inline-flex text-xs leading-5 font-semibold rounded-full ${roleColor} uppercase">
                                        ${user.role}
                                    </span>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400">${date}</td>
                            </tr>
                        `;
                        usersTbody.insertAdjacentHTML('beforeend', row);
                    });
                }

            } catch (error) {
                showToast(error.message || "Failed to load dashboard data.", "error");
            }
        }

        async function adminLogout() {
            if (!confirm('Are you sure you want to logout?')) return;
            try {
                const response = await fetch('/auth/api/auth/logout', { method: 'POST' });
                if (response.ok) {
                    window.location.href = '/admin/login';
                }
            } catch (error) {
                console.error('Logout error:', error);
            }
        }
    </script>
</body>
</html>
