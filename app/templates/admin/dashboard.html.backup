                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-white">Mama Tolu's Kitchen</td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-white">Funke Akindele</td>
